FROM python:3.11-slim
WORKDIR /app

# Install system dependencies (for moviepy/Pillow)
RUN apt-get update && apt-get install -y \
    ffmpeg \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8000

# Single process — all services mounted under one uvicorn
CMD ["uvicorn", "app_consolidated:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
