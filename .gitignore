# General
**/node_modules/
**/__pycache__/
**/*.pyc
.DS_Store
Thumbs.db
*.webm
*.db
.env
.env.*

# Backend specific
backend/uploads/
backend/mockmate.db

# Frontend specific
frontend/dist/
frontend/node_modules/
frontend/.vercel/

# AWS SAM build artifacts (large, auto-generated)
aws/.aws-sam/
aws/.aws-sam/**

# Lambda backend bundles — auto-copied by build.ps1 / GitHub Actions
# Do NOT commit these — they are rebuilt at CI time from backend/
aws/lambda/**/backend/

# SAM local overrides — samconfig.toml is committed, but local test overrides are not
aws/samconfig.local.toml

# AWS credentials — NEVER commit these
.aws/
aws-exports.js

# Docker
.docker/

# Render deploy artifacts
.render/

# IDE
.vscode/
.idea/
*.swp
*.swo
